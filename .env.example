# InvestmentApp — Environment Variables
# Copy this file to .env.local and fill in your keys
# このファイルを .env.local にコピーしてキーを入力してください

# === AI API Keys ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROK_API_KEY=your_grok_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# === Data API Keys ===
NEWS_API_KEY=your_newsapi_key_here
FRED_API_KEY=your_fred_api_key_here

# === Financial Services (Optional / Personal) ===
# SBI証券（自動取得用・任意）
SBI_USER_ID=your_sbi_user_id_here
SBI_PASSWORD=your_sbi_password_here

# マネーフォワード（自動取得用・任意）
MF_EMAIL=your_moneyforward_email_here
MF_PASSWORD=your_moneyforward_password_here
